{
  "name": "squeezit",
  "version": "1.5.0",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "squeezit": "./dist/cli.js",
    "sqz": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./gulp": {
      "import": {
        "types": "./dist/gulp.d.ts",
        "default": "./dist/gulp.js"
      },
      "require": {
        "types": "./dist/gulp.d.cts",
        "default": "./dist/gulp.cjs"
      }
    },
    "./grunt": {
      "import": {
        "types": "./dist/grunt.d.ts",
        "default": "./dist/grunt.js"
      },
      "require": {
        "types": "./dist/grunt.d.cts",
        "default": "./dist/grunt.cjs"
      }
    },
    "./webpack": {
      "import": {
        "types": "./dist/webpack.d.ts",
        "default": "./dist/webpack.js"
      },
      "require": {
        "types": "./dist/webpack.d.cts",
        "default": "./dist/webpack.cjs"
      }
    },
    "./rollup": {
      "import": {
        "types": "./dist/rollup.d.ts",
        "default": "./dist/rollup.js"
      },
      "require": {
        "types": "./dist/rollup.d.cts",
        "default": "./dist/rollup.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/next.d.ts",
        "default": "./dist/next.js"
      },
      "require": {
        "types": "./dist/next.d.cts",
        "default": "./dist/next.cjs"
      }
    },
    "./esbuild": {
      "import": {
        "types": "./dist/esbuild.d.ts",
        "default": "./dist/esbuild.js"
      },
      "require": {
        "types": "./dist/esbuild.d.cts",
        "default": "./dist/esbuild.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "assets",
    "docs",
    "dist",
    "postinstall.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup && bun build ./index.ts --outfile ./dist/cli.js --target node",
    "prepack": "bun run build",
    "postinstall": "node ./postinstall.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check:exports": "publint",
    "check:types": "HUSKY=0 npm_config_cache=.npm-cache attw --pack . --profile node16",
    "fixture-values": "bun run scripts/fixture-values.ts",
    "release:initial": "git fetch --tags --force && $ bunx -- commit-and-tag-version --release-as v1.0.0",
    "release": "git fetch --tags --force && commit-and-tag-version",
    "push": "git push --follow-tags",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.0.7",
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/bun": "latest",
    "commit-and-tag-version": "^12.7.0",
    "cz-git": "^1.12.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.15",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tsup": "^8.5.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "inquirer": "^13.3.2",
    "ora": "^9.3.0"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
