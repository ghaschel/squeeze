{
  "name": "squeezit",
  "version": "1.15.0",
  "description": "Lossless image optimizer CLI, JS/TS API, and bundler plugins for PNG, JPEG, GIF, WebP, SVG, AVIF, HEIC, JXL, ICO, BMP, and more.",
  "license": "MIT",
  "homepage": "https://github.com/ghaschel/squeeze#readme",
  "bugs": {
    "url": "https://github.com/ghaschel/squeeze/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ghaschel/squeeze.git"
  },
  "keywords": [
    "squeezit",
    "image",
    "images",
    "image-compression",
    "image-optimizer",
    "image-optimization",
    "lossless",
    "lossless-compression",
    "compress-images",
    "optimize-images",
    "cli",
    "javascript",
    "typescript",
    "vite-plugin",
    "webpack-plugin",
    "rollup-plugin",
    "esbuild-plugin",
    "gulp-plugin",
    "grunt-plugin",
    "nextjs",
    "png",
    "jpeg",
    "webp",
    "avif",
    "heic",
    "svg"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "squeezit": "./dist/cli.js",
    "sqz": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./gulp": {
      "import": {
        "types": "./dist/gulp.d.ts",
        "default": "./dist/gulp.js"
      },
      "require": {
        "types": "./dist/gulp.d.cts",
        "default": "./dist/gulp.cjs"
      }
    },
    "./grunt": {
      "import": {
        "types": "./dist/grunt.d.ts",
        "default": "./dist/grunt.js"
      },
      "require": {
        "types": "./dist/grunt.d.cts",
        "default": "./dist/grunt.cjs"
      }
    },
    "./webpack": {
      "import": {
        "types": "./dist/webpack.d.ts",
        "default": "./dist/webpack.js"
      },
      "require": {
        "types": "./dist/webpack.d.cts",
        "default": "./dist/webpack.cjs"
      }
    },
    "./rollup": {
      "import": {
        "types": "./dist/rollup.d.ts",
        "default": "./dist/rollup.js"
      },
      "require": {
        "types": "./dist/rollup.d.cts",
        "default": "./dist/rollup.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/next.d.ts",
        "default": "./dist/next.js"
      },
      "require": {
        "types": "./dist/next.d.cts",
        "default": "./dist/next.cjs"
      }
    },
    "./esbuild": {
      "import": {
        "types": "./dist/esbuild.d.ts",
        "default": "./dist/esbuild.js"
      },
      "require": {
        "types": "./dist/esbuild.d.cts",
        "default": "./dist/esbuild.cjs"
      }
    },
    "./babel": {
      "import": {
        "types": "./dist/babel.d.ts",
        "default": "./dist/babel.js"
      },
      "require": {
        "types": "./dist/babel.d.cts",
        "default": "./dist/babel.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "assets",
    "docs",
    "dist",
    "postinstall.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup && bun build ./index.ts --outfile ./dist/cli.js --target node",
    "prepack": "bun run build",
    "postinstall": "node ./postinstall.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:api": "bun run build && vitest run tests/integration/api.test.ts",
    "test:cli": "vitest run tests/unit/cli.test.ts",
    "test:babel": "bun run build && vitest run tests/integration/babel.test.ts",
    "test:gulp": "vitest run tests/integration/gulp.test.ts",
    "test:grunt": "bun run build && vitest run tests/integration/grunt.test.ts",
    "test:esbuild": "vitest run tests/integration/esbuild.test.ts",
    "test:rollup": "vitest run tests/integration/rollup.test.ts",
    "test:vite": "vitest run tests/integration/vite.test.ts",
    "test:webpack": "vitest run tests/integration/webpack.test.ts",
    "test:next": "bun run build && vitest run tests/integration/next.test.ts",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check:exports": "publint",
    "check:types": "HUSKY=0 npm_config_cache=.npm-cache attw --pack . --profile node16",
    "fixture-values": "bun run scripts/fixture-values.ts",
    "release:initial": "git fetch --tags --force && $ bunx -- commit-and-tag-version --release-as v1.0.0",
    "release": "git fetch --tags --force && commit-and-tag-version",
    "push": "git push --follow-tags",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@babel/core": "^7.0.0",
    "@eslint/js": "^10.0.1",
    "@types/babel__core": "^7.20.5",
    "@types/gulp": "^4.0.17",
    "@types/vinyl": "^2.0.12",
    "@vitest/coverage-v8": "^4.0.7",
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/bun": "latest",
    "commit-and-tag-version": "^12.7.0",
    "cz-git": "^1.12.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "esbuild": "^0.27.4",
    "husky": "^9.1.7",
    "gulp": "^5.0.1",
    "grunt": "^1.6.1",
    "lint-staged": "^16.4.0",
    "next": "^16.2.1",
    "prettier": "^3.8.1",
    "publint": "^0.3.15",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rollup": "^4.52.3",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tsup": "^8.5.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.2",
    "vitest": "^4.0.7",
    "vinyl": "^3.0.1",
    "webpack": "^5.105.4"
  },
  "peerDependencies": {
    "@babel/core": "^7.0.0",
    "esbuild": "^0.27.4",
    "gulp": "^5.0.1",
    "grunt": "^1.6.1",
    "next": "^16.2.1",
    "rollup": "^4.52.3",
    "typescript": "^5",
    "vite": "^8.0.2",
    "webpack": "^5.105.4"
  },
  "peerDependenciesMeta": {
    "@babel/core": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "gulp": {
      "optional": true
    },
    "grunt": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "inquirer": "^13.3.2",
    "ora": "^9.3.0"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
